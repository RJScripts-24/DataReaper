APP_NAME=DataReaper Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
APP_SECRET_KEY=change-me
APP_ENABLE_DEMO_MODE=true
APP_AUTO_CREATE_TABLES=true

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require
SYNC_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

PLAYWRIGHT_HEADLESS=true
LOCAL_STORAGE_PATH=./storage
